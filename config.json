    "compute_type": "int8",
    "language": "en"
  },
  "tts": {
    "provider": "piper",
    "model": "en_US-ryan-high",
    "fallback_to_beep": true
  },
  "interruption": {
    "enabled": true,
    "sensitivity": 0.5,
    "latency_ms": 100
  }
